      <div class="entry" id="accountName">Teacher account loaded.</div>
      <div class="entry" id="accountCell">You can now enter the main interface.</div>
      <button class="btn" id="enterMain">Enter Main Interface</button>
    </div>
  </div>

  <script>
    const authCard = document.getElementById('authCard');
    const heroPanel = document.getElementById('heroPanel');
    const authShell = document.getElementById('authShell');
    const dashboardShell = document.getElementById('dashboardShell');
    const mainAction = document.getElementById('mainAction');
    const switchMode = document.getElementById('switchMode');
    const forgotLink = document.getElementById('forgotLink');
    const statusText = document.getElementById('statusText');
    const verifyOverlay = document.getElementById('verifyOverlay');
    const forgotOverlay = document.getElementById('forgotOverlay');
    const accountOverlay = document.getElementById('accountOverlay');
    const devicePill = document.getElementById('devicePill');
    const cardBadge = document.getElementById('cardBadge');
    const togglePassword = document.getElementById('togglePassword');
    const toggleLoginPassword = document.getElementById('toggleLoginPassword');
    const verifyBtn = document.getElementById('verifyBtn');
    const resetBtn = document.getElementById('resetBtn');
    const closeForgot = document.getElementById('closeForgot');
    const enterMain = document.getElementById('enterMain');
    const profilePhotoBtn = document.getElementById('profilePhotoBtn');
    const navButtons = document.querySelectorAll('.nav-item');
    const viewPanels = document.querySelectorAll('.view-panel');

    let mode = 'register';
    let pendingUser = null;

    // Device detection for mobile vs desktop features
    const deviceType = (() => {
      const ua = navigator.userAgent.toLowerCase();
      const isMobile = /iphone|android|mobile/.test(ua) || navigator.maxTouchPoints > 2;
      return isMobile ? 'mobile' : 'desktop';
    })();

    async function requestJson(url, options = {}) {
      const response = await fetch(url, {
        headers: { 'Content-Type': 'application/json' },
        ...options,
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.error || 'Request failed.');
      }

      return data;
    }

    function updateMode() {
      authCard.classList.toggle('register-mode', mode === 'register');
      authCard.classList.toggle('login-mode', mode === 'login');
      mainAction.textContent = mode === 'register' ? 'Register' : 'Log in';
      cardBadge.textContent = mode === 'register' ? 'New User' : 'Existing User';
      statusText.textContent = mode === 'register'
        ? 'Please fill in the details to continue.'
        : 'Welcome back. Use your registered username and password.';
      statusText.className = 'status';
    }

    function setStatus(text, type = '') {
      statusText.textContent = text;
      statusText.className = 'status' + (type ? ` ${type}` : '');
    }

    function animateCard() {
      authCard.classList.add('immersed');
      heroPanel.classList.add('hide-hero');
    }

    function resetCard() {
      authCard.classList.remove('immersed', 'invalid');
      heroPanel.classList.remove('hide-hero');
    }

    function isStrongPassword(value) {
      return value.length >= 8 && /[A-Z]/.test(value) && /\d/.test(value);
    }

    function showOverlay(overlay) {
      overlay.classList.add('show');
    }

    function hideOverlay(overlay) {
      overlay.classList.remove('show');
    }

    function togglePasswordField(inputId) {
      const input = document.getElementById(inputId);
      input.type = input.type === 'password' ? 'text' : 'password';
    }

    async function changePassword() {
      const current = document.getElementById('currentPassword').value;
      const newPass = document.getElementById('newPasswordField').value;
      const confirm = document.getElementById('confirmPasswordField').value;
      const statusDiv = document.getElementById('passwordStatus');

      if (!current || !newPass || !confirm) {
        statusDiv.textContent = 'Please fill in all fields.';
        statusDiv.className = 'status error';
        return;
      }

      if (newPass !== confirm) {
        statusDiv.textContent = 'New passwords do not match.';
        statusDiv.className = 'status error';
        return;
      }

      if (!isStrongPassword(newPass)) {
        statusDiv.textContent = 'Password must be 8+ characters, uppercase letter, and a number.';
        statusDiv.className = 'status error';
        return;
      }

      try {
        const data = await requestJson('/api/change-password', {
          method: 'POST',
          body: JSON.stringify({ 
            username: localStorage.getItem('currentUsername'),
            currentPassword: current, 
            newPassword: newPass 
          }),
        });

        statusDiv.textContent = data.message || 'Password updated successfully!';
        statusDiv.className = 'status success';
        document.getElementById('currentPassword').value = '';
        document.getElementById('newPasswordField').value = '';
        document.getElementById('confirmPasswordField').value = '';
      } catch (error) {
        statusDiv.textContent = error.message;
        statusDiv.className = 'status error';
      }
    }

    async function loadPendingRequests() {
      const requestsList = document.getElementById('requestsList');
      try {
        const data = await requestJson('/api/admin/pending-requests', {
          method: 'POST',
          body: JSON.stringify({ adminUsername: localStorage.getItem('currentUsername') }),
        });

        if (!data.requests || data.requests.length === 0) {
          requestsList.innerHTML = '<p style="text-align:center; color:#999;">No pending requests.</p>';
          return;
        }

        requestsList.innerHTML = data.requests.map((req, idx) => `
          <div style="padding:0.8rem; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
            <div>
              <p style="margin:0; font-weight:700; font-size:0.95rem;">${req.username}</p>
              <p style="margin:0.2rem 0 0; font-size:0.85rem; color:#666;">Requested: ${new Date(req.requested_at).toLocaleString()}</p>
            </div>
            <div style="display:flex; gap:0.3rem;">
              <button class="btn" onclick="approveRequest(${req.id})" style="padding:0.4rem 0.8rem; font-size:0.85rem; background:#10b981;">Approve</button>
              <button class="link-btn" onclick="rejectRequest(${req.id})" style="padding:0.4rem 0.8rem; font-size:0.85rem; color:#b91c1c;">Reject</button>
            </div>
          </div>
        `).join('');
      } catch (error) {
        requestsList.innerHTML = `<p style="color:#b91c1c;">${error.message}</p>`;
      }
    }

    async function approveRequest(requestId) {
      try {
        const data = await requestJson('/api/admin/approve-request', {
          method: 'POST',
          body: JSON.stringify({ 
            requestId, 
            adminUsername: localStorage.getItem('currentUsername') 
          }),
        });
        alert(data.message);
        loadPendingRequests();
      } catch (error) {
        alert('Error: ' + error.message);
      }
    }

    async function rejectRequest(requestId) {
      try {
        const data = await requestJson('/api/admin/reject-request', {
          method: 'POST',
          body: JSON.stringify({ 
            requestId, 
            adminUsername: localStorage.getItem('currentUsername') 
          }),
        });
        alert(data.message);
        loadPendingRequests();
      } catch (error) {
        alert('Error: ' + error.message);
      }
    }

    function initializeAdmin() {
      const adminPanel = document.getElementById('adminPanel');
      const isAdmin = localStorage.getItem('isAdmin') === 'true';
      if (isAdmin) {
        adminPanel.style.display = 'block';
        loadPendingRequests();
        const autoApprove = document.getElementById('autoApprove');
        autoApprove.checked = localStorage.getItem('autoApprove') === 'true';
        autoApprove.addEventListener('change', (e) => {
          localStorage.setItem('autoApprove', e.target.checked);
        });
      }

      // Show QR scanner for mobile devices
      if (deviceType === 'mobile') {
        showQrScanner();
      }
    }

    function detectDevice() {
      const portrait = window.matchMedia('(orientation: portrait)').matches;
      const width = window.innerWidth;
      const height = window.innerHeight;
      const label = portrait ? 'Portrait' : 'Landscape';
      const size = `${width}×${height}`;
      devicePill.textContent = `${label} • ${size}`;
      document.body.classList.toggle('portrait', portrait);
      document.body.classList.toggle('landscape', !portrait);
    }

    function showDashboard() {
      authShell.style.display = 'none';
      dashboardShell.classList.add('show');
    }

    function activateView(viewId) {
      viewPanels.forEach(panel => panel.classList.toggle('active', panel.id === `view-${viewId}`));
      navButtons.forEach(button => button.classList.toggle('active', button.dataset.view === viewId));
    }

    switchMode.addEventListener('click', () => {
      mode = mode === 'register' ? 'login' : 'register';
      updateMode();
      animateCard();
    });

    // Class detail functions for grading room access
    let classGradingData = {};

    function openClassDetail(classId) {
      document.getElementById('classDetail').style.display = 'block';
      
      // Initialize subject data if not exists
      if (!classGradingData[classId]) {
        classGradingData[classId] = {
          subjects: ['Math', 'English', 'Science'],
          categories: {},
          formulas: {},
          students: {}
        };
      }

      const classData = classGradingData[classId];
      
      if (deviceType === 'desktop') {
        let subjectsHtml = classData.subjects.map((subject, idx) => `
          <div style="display:flex; gap:0.5rem; align-items:center; margin-bottom:0.5rem;">
            <input type="text" value="${subject}" class="subjectInput" data-index="${idx}" style="flex:1; padding:0.4rem; border:1px solid #ddd; border-radius:8px;" />
            <button class="link-btn" onclick="removeSubject('${classId}', ${idx})" style="color:#b91c1c; font-size:0.85rem;">Remove</button>
          </div>
        `).join('');

        let categoriesHtml = classData.subjects.map((subject) => {
          const cats = classData.categories[subject] || [];
          return `
            <div style="margin-bottom:1rem; padding:0.8rem; background:#fafaf9; border-radius:8px;">
              <p style="margin:0 0 0.5rem; font-weight:700; font-size:0.9rem;">${subject}</p>
              <div id="categories-${subject}" style="display:flex; flex-direction:column; gap:0.4rem;">
                ${cats.map((cat, idx) => `
                  <div style="display:flex; gap:0.3rem; align-items:center;">
                    <input type="text" value="${cat.name}" placeholder="Category" style="flex:1; padding:0.3rem; border:1px solid #ddd; border-radius:6px; font-size:0.85rem;" />
                    <input type="number" value="${cat.weight}" placeholder="%" min="0" max="100" style="width:50px; padding:0.3rem; border:1px solid #ddd; border-radius:6px; font-size:0.85rem;" onchange="updateCategory('${classId}', '${subject}', ${idx}, this.value)" />
                    <button class="link-btn" onclick="deleteCategory('${classId}', '${subject}', ${idx})" style="color:#b91c1c; font-size:0.75rem; padding:0.2rem;">✕</button>
                  </div>
                `).join('')}
              </div>
              <button class="link-btn" onclick="addCategory('${classId}', '${subject}')" style="font-size:0.85rem; margin-top:0.4rem;">+ Add Category</button>
            </div>
          `;
        }).join('');

        let formulaInputs = classData.subjects.map((subject) => `
          <div style="margin-bottom:0.8rem;">
            <label style="font-weight:700; font-size:0.85rem;">${subject} Formula</label>
            <input type="text" id="formula-${subject}" value="${classData.formulas[subject] || '(Q1+Q2+Q3+Q4)/4'}" placeholder="e.g., (Q1+Q2)/2 or MAX(Q1,Q2,Q3)" style="width:100%; padding:0.5rem; border:1px solid #ddd; border-radius:8px; font-size:0.85rem;" onchange="updateFormula('${classId}', '${subject}', this.value)" />
            <p style="font-size:0.75rem; color:#666; margin:0.3rem 0 0;">Use category initials or indices (Q1, Q2, etc.)</p>
          </div>
        `).join('');

        document.getElementById('classContent').innerHTML = `
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
            <div class="panel-card" style="background:linear-gradient(145deg,#f0e8d8,#e9dcc8);">
              <h4 style="margin:0 0 0.8rem; color:var(--blue); font-size:0.95rem;">Subject Grading Sheet</h4>
              <div class="form-grid">
                <label style="font-weight:700; font-size:0.85rem;">Manage Subjects</label>
                ${subjectsHtml}
                <button class="btn" onclick="addNewSubject('${classId}')" style="margin-top:0.5rem; font-size:0.9rem;">+ Add Subject</button>
              </div>
            </div>
            <div class="panel-card" style="background:linear-gradient(145deg,#f5f0e0,#ede2cc);">
              <h4 style="margin:0 0 0.8rem; color:var(--blue); font-size:0.95rem;">Categories & Weights</h4>
              <div class="form-grid">
                ${categoriesHtml}
              </div>
            </div>
          </div>

          <div class="panel-card" style="background:linear-gradient(145deg,#e0f0f9,#cce3f0); margin-top:1rem;">
            <h4 style="margin:0 0 0.8rem; color:var(--blue); font-size:0.95rem;">Grade Calculation Formulas</h4>
            <div class="form-grid">
              ${formulaInputs}
              <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.5rem; margin-top:0.8rem;">
                <button class="btn" onclick="saveFomulas('${classId}')">Save Formulas</button>
                <button class="btn" onclick="exportGradesToExcel('${classId}')" style="background:#10b981;">Export to Excel</button>
              </div>
            </div>
          </div>
        `;

        // Attach save functionality for subject names
        document.querySelectorAll('.subjectInput').forEach(input => {
          input.addEventListener('change', (e) => {
            const idx = parseInt(e.target.dataset.index);
            classData.subjects[idx] = e.target.value || `Subject ${idx + 1}`;
          });
        });
      } else {
        document.getElementById('classContent').innerHTML = `
          <div class="form-grid">
            <p>Grading room is only available on desktop/tablet.</p>
            <p style="font-weight:700;">Mobile features: Attendance scanning and messaging coming soon.</p>
          </div>
        `;
      }
    }

    function addCategory(classId, subject) {
      if (!classGradingData[classId].categories[subject]) {
        classGradingData[classId].categories[subject] = [];
      }
      classGradingData[classId].categories[subject].push({ name: 'New Category', weight: 0 });
      openClassDetail(classId);
    }

    function deleteCategory(classId, subject, idx) {
      if (classGradingData[classId].categories[subject]) {
        classGradingData[classId].categories[subject].splice(idx, 1);
        openClassDetail(classId);
      }
    }

    function updateCategory(classId, subject, idx, weight) {
      if (classGradingData[classId].categories[subject]) {
        classGradingData[classId].categories[subject][idx].weight = parseFloat(weight) || 0;
      }
    }

    function updateFormula(classId, subject, formula) {
      classGradingData[classId].formulas[subject] = formula;
    }

    function addNewSubject(classId) {
      if (classGradingData[classId]) {
        classGradingData[classId].subjects.push(`Subject ${classGradingData[classId].subjects.length + 1}`);
        openClassDetail(classId);
      }
    }

    function removeSubject(classId, idx) {
      if (classGradingData[classId]) {
        classGradingData[classId].subjects.splice(idx, 1);
        openClassDetail(classId);
      }
    }

    function backToClasses() {
      document.getElementById('classDetail').style.display = 'none';
    }

    mainAction.addEventListener('click', async () => {
      if (mode === 'register') {
        const username = document.getElementById('username').value.trim();
        const cell = document.getElementById('cell').value.trim() || 'N/A';
        const password = document.getElementById('password').value;
        const countryCode = document.getElementById('countryCode').value;

        if (!username || !password) {
          authCard.classList.add('invalid');
          setStatus('Please enter username and password.', 'error');
          return;
        }

        if (!isStrongPassword(password)) {
          authCard.classList.add('invalid');
          setStatus('Password is too weak. Use 8+ chars, uppercase and a number.', 'error');
          return;
        }

        try {
          const data = await requestJson('/api/register', {
            method: 'POST',
            body: JSON.stringify({ username, cell, password, countryCode }),
          });

          animateCard();
          localStorage.setItem('currentUsername', data.user.username);
          localStorage.setItem('isAdmin', data.user.is_admin || false);
          document.getElementById('accountName').textContent = `Welcome ${data.user.username}`;
          document.getElementById('accountCell').textContent = `Registration successful. Enter the main interface.`;
          showOverlay(accountOverlay);
        } catch (error) {
          authCard.classList.add('invalid');
          setStatus(error.message, 'error');
        }
      } else {
        const loginUser = document.getElementById('loginUser').value.trim();
        const loginPassword = document.getElementById('loginPassword').value;

        try {
          const data = await requestJson('/api/login', {
            method: 'POST',
            body: JSON.stringify({ username: loginUser, password: loginPassword }),
          });

          animateCard();
          localStorage.setItem('currentUsername', data.user.username);
          localStorage.setItem('isAdmin', data.user.is_admin || false);
          document.getElementById('accountName').textContent = `Welcome back ${data.user.username}`;
          document.getElementById('accountCell').textContent = `Ready to access the main interface.`;
          showOverlay(accountOverlay);
        } catch (error) {
          authCard.classList.add('invalid');
          setStatus(error.message, 'error');
        }
      }
    });

    togglePassword.addEventListener('click', () => {
      const input = document.getElementById('password');
      input.type = input.type === 'password' ? 'text' : 'password';
      togglePassword.textContent = input.type === 'password' ? 'SHOW' : 'HIDE';
    });

    toggleLoginPassword.addEventListener('click', () => {
      const input = document.getElementById('loginPassword');
      input.type = input.type === 'password' ? 'text' : 'password';
      toggleLoginPassword.textContent = input.type === 'password' ? 'SHOW' : 'HIDE';
    });

    enterMain.addEventListener('click', () => {
      hideOverlay(accountOverlay);
      setStatus('Main interface is ready. Connect this to your dashboard next.', 'success');
      resetCard();
      showDashboard();
      initializeAdmin();
    });

    navButtons.forEach(button => {
      button.addEventListener('click', () => activateView(button.dataset.view));
    });

    profilePhotoBtn.addEventListener('click', () => activateView('account'));

    document.querySelectorAll('input').forEach(input => {
      input.addEventListener('focus', () => {
        authCard.classList.remove('invalid');
      });
    });

    window.addEventListener('resize', detectDevice);
    window.addEventListener('orientationchange', detectDevice);
    detectDevice();
    updateMode();

    // QR Scanner for Mobile Attendance
    let attendanceData = {};
    let isScanning = false;

    function showQrScanner() {
      const qrCard = document.getElementById('qrScannerCard');
      if (deviceType === 'mobile') {
        qrCard.style.display = 'block';
        loadClasses();
      }
    }

    function loadClasses() {
      const classSelect = document.getElementById('classSelect');
      const classes = ['Grade 8 - A (Math)', 'Grade 8 - B (English)', 'Grade 9 - A (Science)'];
      classSelect.innerHTML = '<option value="">Select class</option>' + 
        classes.map(c => `<option value="${c}">${c}</option>`).join('');
    }

    async function startQrScanner() {
      const classSelected = document.getElementById('classSelect').value;
      if (!classSelected) {
        alert('Please select a class first.');
        return;
      }

      isScanning = true;
      const video = document.getElementById('qrVideo');
      const container = document.getElementById('qrContainer');
      const status = document.getElementById('scannerStatus');
      
      container.style.display = 'block';
      status.style.display = 'block';

      try {
        const stream = await navigator.mediaDevices.getUserMedia({ 
          video: { facingMode: 'environment' } 
        });
        video.srcObject = stream;
        video.play();

        scanQrCode(video, classSelected);
      } catch (error) {
        document.getElementById('statusText').textContent = 'Camera access denied.';
        isScanning = false;
      }
    }

    function scanQrCode(video, classSelected) {
      const canvas = document.createElement('canvas');
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      const ctx = canvas.getContext('2d');

      function scan() {
        if (!isScanning) return;

        if (video.readyState === video.HAVE_ENOUGH_DATA) {
          ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
          const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
          const code = jsQR(imageData.data, imageData.width, imageData.height);

          if (code) {
            handleQrData(code.data, classSelected);
          }
        }
        requestAnimationFrame(scan);
      }

      scan();
    }

    function handleQrData(data, classSelected) {
      const statusText = document.getElementById('statusText');
      
      if (!attendanceData[classSelected]) {
        attendanceData[classSelected] = [];
      }

      const existing = attendanceData[classSelected].find(s => s.lrn === data);
      if (existing) {
        existing.time = new Date().toLocaleTimeString();
        statusText.textContent = `✓ ${data} already marked at ${existing.time}`;
      } else {
        attendanceData[classSelected].push({ 
          lrn: data, 
          time: new Date().toLocaleTimeString(),
          status: 'present'
        });
        statusText.textContent = `✓ ${data} marked present`;
      }

      updateAttendanceList(classSelected);
    }

    function updateAttendanceList(classSelected) {
      const list = document.getElementById('attendanceList');
      const records = attendanceData[classSelected] || [];
      
      list.innerHTML = records.map((record, idx) => `
        <div style="padding:0.6rem; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
          <div>
            <p style="margin:0; font-weight:700;">${record.lrn}</p>
            <p style="margin:0.2rem 0 0; font-size:0.8rem; color:#666;">${record.time}</p>
          </div>
          <div style="display:flex; gap:0.3rem;">
            <button class="link-btn" onclick="editAttendance('${classSelected}', ${idx}, 'present')" style="font-size:0.8rem; ${record.status === 'present' ? 'color:#10b981;' : ''}">Present</button>
            <button class="link-btn" onclick="editAttendance('${classSelected}', ${idx}, 'sick')" style="font-size:0.8rem; ${record.status === 'sick' ? 'color:#f59e0b;' : ''}">Sick</button>
            <button class="link-btn" onclick="editAttendance('${classSelected}', ${idx}, 'absent')" style="font-size:0.8rem; ${record.status === 'absent' ? 'color:#b91c1c;' : ''}">Absent</button>
          </div>
        </div>
      `).join('');
    }

    function editAttendance(classSelected, idx, status) {
      if (attendanceData[classSelected] && attendanceData[classSelected][idx]) {
        attendanceData[classSelected][idx].status = status;
        updateAttendanceList(classSelected);
      }
    }

    function stopQrScanner() {
      isScanning = false;
      const video = document.getElementById('qrVideo');
      if (video.srcObject) {
        video.srcObject.getTracks().forEach(track => track.stop());
      }
      document.getElementById('qrContainer').style.display = 'none';
      document.getElementById('scannerStatus').style.display = 'none';
    }

    function exportGradesToExcel(classId) {
      if (!classGradingData[classId]) return;

      const classData = classGradingData[classId];
      const wb = XLSX.utils.book_new();
      
      // Create sheet for each subject
      classData.subjects.forEach(subject => {
        const sheetData = [];
        
        // Header row
        sheetData.push(['Subject: ' + subject, 'Formula: ' + (classData.formulas[subject] || 'N/A')]);
        sheetData.push([]);
        
        // Categories header
        const categories = classData.categories[subject] || [];
        const categoryHeaders = ['LRN', ...categories.map(c => c.name + ` (${c.weight}%)`)];
        sheetData.push(categoryHeaders);
        
        // Sample data row (can be extended with actual student data)
        if (Object.keys(classData.students).length > 0) {
          Object.entries(classData.students).forEach(([lrn, grades]) => {
            const row = [lrn, ...categories.map(c => grades[c.name] || '')];
            sheetData.push(row);
          });
        }

        const ws = XLSX.utils.aoa_to_sheet(sheetData);
        XLSX.utils.book_append_sheet(wb, ws, subject.substring(0, 31));
      });

      // Attendance sheet
      const attendanceData = [];
      attendanceData.push(['Class', 'Date/Time', 'Total Scanned']);
      Object.entries(attendanceData).forEach(([cls, records]) => {
        attendanceData.push([cls, new Date().toLocaleString(), records.length]);
      });
      const attendanceWs = XLSX.utils.aoa_to_sheet(attendanceData);
      XLSX.utils.book_append_sheet(wb, attendanceWs, 'Attendance');

      // Write file
      const filename = `grades_${classId}_${new Date().toISOString().slice(0, 10)}.xlsx`;
      XLSX.writeFile(wb, filename);
      alert('Grades exported to ' + filename);
    }

    function exportAttendanceToExcel() {
      const attendanceData = [];
      attendanceData.push(['Class', 'Date', 'Present', 'Sick', 'Absent']);

      Object.entries(attendanceData).forEach(([classId, records]) => {
        const present = records.filter(r => r.status === 'present').length;
        const sick = records.filter(r => r.status === 'sick').length;
        const absent = records.filter(r => r.status === 'absent').length;
        attendanceData.push([classId, new Date().toLocaleString(), present, sick, absent]);
      });

      const ws = XLSX.utils.aoa_to_sheet(attendanceData);
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'Attendance');

      const filename = `attendance_${new Date().toISOString().slice(0, 10)}.xlsx`;
      XLSX.writeFile(wb, filename);
      alert('Attendance exported to ' + filename);
    }

    // Messaging System
    let currentRecipient = '';
    let messagesLog = [];

    function selectRecipient(element, recipient) {
      document.querySelectorAll('#recipientList div').forEach(e => e.style.background = '');
      element.style.background = '#e7c76e';
      currentRecipient = recipient;
    }

    function sendMessage() {
      const msg = document.getElementById('messageInput').value;
      if (!msg || !currentRecipient) {
        alert('Select recipient and type a message.');
        return;
      }

      messagesLog.push({
        recipient: currentRecipient,
        message: msg,
        timestamp: new Date().toLocaleString(),
        sender: localStorage.getItem('currentUsername')
      });

      document.getElementById('messageInput').value = '';
      alert(`Message sent to ${currentRecipient}`);
    }

    // Student Management
    let studentsDB = {};

    function addStudent() {
      const name = document.getElementById('studentName').value;
      const lrn = document.getElementById('studentLRN').value;
      const cls = document.getElementById('studentClass').value;

      if (!name || !lrn || cls === 'Select Class') {
        alert('Please fill in all fields.');
        return;
      }

      if (!studentsDB[cls]) studentsDB[cls] = [];
      studentsDB[cls].push({ name, lrn, dateAdded: new Date().toLocaleString() });

      document.getElementById('studentName').value = '';
      document.getElementById('studentLRN').value = '';
      alert(`${name} added to ${cls}`);
    }

    function importCSV() {
      const file = document.getElementById('csvFile').files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (e) => {
        const csv = e.target.result;
        const rows = csv.split('\n');
        let imported = 0;

        rows.forEach((row, idx) => {
          if (idx === 0 || !row.trim()) return;
          const [name, lrn, cls] = row.split(',').map(s => s.trim());
          if (name && lrn && cls) {
            if (!studentsDB[cls]) studentsDB[cls] = [];
            studentsDB[cls].push({ name, lrn, dateAdded: new Date().toLocaleString() });
            imported++;
          }
        });

        alert(`${imported} students imported successfully!`);
        document.getElementById('csvFile').value = '';
      };

      reader.readAsText(file);
    }

    // Database Backup & Restore
    function backupDatabase() {
      const backup = {
        grading: classGradingData,
        attendance: attendanceData,
        students: studentsDB,
        messages: messagesLog,
        timestamp: new Date().toISOString()
      };

      const dataStr = JSON.stringify(backup, null, 2);
      const dataBlob = new Blob([dataStr], { type: 'application/json' });
      const url = URL.createObjectURL(dataBlob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `MAACSYS_backup_${new Date().toISOString().slice(0, 10)}.json`;
      link.click();
      URL.revokeObjectURL(url);
      alert('Backup downloaded successfully!');
    }

    function restoreDatabase() {
      const file = document.getElementById('backupFile').files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          const backup = JSON.parse(e.target.result);
          classGradingData = backup.grading || {};
          attendanceData = backup.attendance || {};
          studentsDB = backup.students || {};
          messagesLog = backup.messages || [];
          alert('Database restored successfully!');
          document.getElementById('backupFile').value = '';
        } catch (error) {
          alert('Invalid backup file: ' + error.message);
        }
      };

      reader.readAsText(file);
    }

  </script>
