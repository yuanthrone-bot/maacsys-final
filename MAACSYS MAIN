<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover" />
  <title>MAACSYS</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jsQR/1.4.0/jsQR.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.min.js"></script>
  <style>
    :root {
      --navy: #0f2a4b;
      --champagne: #f3e1b0;
      --champagne-2: #e7c76e;
      --blue: #163c6b;
      --yellow: #f7d14d;
      --text: #111111;
      --danger: #b91c1c;
      --shadow: rgba(15, 42, 75, 0.2);
      --card-radius: 26px;
    }

    * { box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      margin: 0;
      overflow: hidden;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background: var(--navy);
      color: var(--text);
      overscroll-behavior: none;
      -webkit-user-select: none;
      user-select: none;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: radial-gradient(circle at top left, rgba(255,255,255,0.18), transparent 20%);
      pointer-events: none;
    }

    .app-shell {
      width: 100vw;
      height: 100dvh;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 0;
      padding: 0;
      overflow: hidden;
      position: relative;
      transition: all 0.7s ease;
    }

    .hero-panel {
      padding: 2rem 2rem 2rem 2.8rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: clamp(0.8rem, 2vw, 1.4rem);
      color: var(--yellow);
      position: relative;
      z-index: 2;
      transition: all 0.7s ease;
      transform: translateX(0);
      opacity: 1;
    }

    .hero-panel .eyebrow {
      font-size: 0.95rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      font-weight: 700;
      opacity: 0.9;
    }

    .hero-panel h1 {
      font-size: clamp(2.2rem, 4vw, 3.6rem);
      margin: 0;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--yellow);
    }

    .hero-panel .description {
      font-size: clamp(1rem, 1.5vw, 1.16rem);
      max-width: 36rem;
      line-height: 1.6;
      margin: 0;
      color: #fbe7a8;
    }

    .hero-panel .highlight {
      color: #fff3c7;
      font-weight: 700;
    }

    .form-panel {
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 1.25rem;
      position: relative;
      min-width: 0;
    }

    .auth-card {
      width: min(100%, 460px);
      background: linear-gradient(145deg, var(--champagne), var(--champagne-2));
      border-radius: var(--card-radius);
      box-shadow: 0 18px 45px var(--shadow);
      padding: 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      transition: transform 0.7s ease, width 0.7s ease, padding 0.7s ease, box-shadow 0.7s ease;
      transform: translateY(0) scale(1);
      position: relative;
      z-index: 3;
      border: 2px solid rgba(0,0,0,0.08);
    }

    .auth-card .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 0.2rem;
    }

    .auth-card .card-header .tiny {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      opacity: 0.8;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .field label {
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--navy);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .field input, .field select {
      border: 1px solid rgba(15, 42, 75, 0.18);
      border-radius: 14px;
      padding: 0.85rem 0.95rem;
      font-size: 1rem;
      background: rgba(255,255,255,0.65);
      color: var(--text);
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .field input:focus, .field select:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(22, 60, 107, 0.15);
    }

    .password-wrap {
      position: relative;
    }

    .password-wrap .toggle {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      border: none;
      background: transparent;
      color: var(--navy);
      cursor: pointer;
      font-size: 0.8rem;
      font-weight: 700;
    }

    .actions {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
      margin-top: 0.2rem;
    }

    .btn {
      border: none;
      border-radius: 999px;
      padding: 0.95rem 1rem;
      font-size: 1rem;
      font-weight: 800;
      color: #fff;
      background: linear-gradient(145deg, var(--blue), #0d2652);
      box-shadow: 0 10px 20px rgba(13, 38, 82, 0.22);
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .btn:hover { transform: translateY(-1px); }

    .link-btn {
      background: transparent;
      color: var(--navy);
      border: none;
      font-weight: 700;
      cursor: pointer;
      text-align: left;
      padding: 0;
      font-size: 0.95rem;
    }

    .helper-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.8rem;
      flex-wrap: wrap;
    }

    .hint {
      font-size: 0.85rem;
      color: var(--navy);
      opacity: 0.82;
    }

    .status {
      min-height: 1.25rem;
      font-size: 0.92rem;
      color: var(--navy);
      font-weight: 700;
      transition: color 0.3s ease;
    }

    .status.error { color: var(--danger); }

    .status.success { color: #136b2f; }

    .auth-card.immersed {
      width: min(100%, 560px);
      padding: 1.4rem 1.6rem;
      transform: translateY(0) scale(1.01);
      box-shadow: 0 24px 60px rgba(0,0,0,0.25);
    }

    .auth-card.invalid {
      animation: shake 0.35s linear;
    }

    .auth-card.invalid .btn {
      background: linear-gradient(145deg, var(--champagne-2), var(--champagne));
      color: var(--navy);
      box-shadow: 0 10px 20px rgba(245, 208, 92, 0.28);
      animation: crack 0.7s ease forwards;
      position: relative;
      overflow: hidden;
    }

    .auth-card.invalid .btn::after {
      content: "";
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(135deg, transparent 0 8px, rgba(0,0,0,0.08) 8px 10px);
      opacity: 0.4;
      pointer-events: none;
    }

    .auth-card.login-mode .register-only, .auth-card.register-mode .login-only {
      display: none;
    }

    .hero-panel.hide-hero {
      opacity: 0;
      transform: translateX(-16px) scale(0.98);
      pointer-events: none;
    }

    .overlay {
      position: absolute;
      inset: 0;
      background: rgba(9, 20, 39, 0.7);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      z-index: 6;
    }

    .overlay.show { display: flex; }

    .overlay-card {
      background: linear-gradient(145deg, var(--champagne), var(--champagne-2));
      border-radius: 24px;
      width: min(100%, 460px);
      padding: 1.3rem;
      box-shadow: 0 24px 60px rgba(0,0,0,0.3);
    }

    .overlay-card h3 {
      margin: 0 0 0.3rem;
      color: var(--navy);
      font-size: 1.2rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .overlay-card p {
      margin: 0 0 0.8rem;
      color: var(--navy);
      line-height: 1.5;
      font-size: 0.95rem;
    }

    .overlay-card .small {
      font-size: 0.82rem;
      opacity: 0.85;
    }

    .account-card {
      border-radius: 24px;
      background: linear-gradient(145deg, var(--navy), #071427);
      color: white;
      padding: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      box-shadow: 0 24px 60px rgba(0,0,0,0.3);
    }

    .account-card .chip {
      display: inline-flex;
      width: fit-content;
      padding: 0.45rem 0.7rem;
      border-radius: 999px;
      background: rgba(255,255,255,0.14);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .account-card .entry {
      font-size: 0.95rem;
      line-height: 1.5;
      opacity: 0.95;
    }

    .account-card .btn {
      background: linear-gradient(145deg, var(--yellow), #f7a129);
      color: var(--navy);
      margin-top: 0.4rem;
    }

    .device-pill {
      position: absolute;
      left: 1rem;
      bottom: 1rem;
      background: rgba(255,255,255,0.12);
      color: #f8e08a;
      padding: 0.45rem 0.75rem;
      border-radius: 999px;
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      z-index: 4;
    }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      50% { transform: translateX(6px); }
      75% { transform: translateX(-4px); }
    }

    @keyframes crack {
      0% { transform: rotate(0deg); }
      50% { transform: rotate(-1deg) scale(1.02); }
      100% { transform: rotate(0deg) scale(1); }
    }

    @media (orientation: portrait) {
      .app-shell {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr;
      }

      .hero-panel {
        padding: 1.1rem 1.1rem 0.7rem;
        gap: 0.55rem;
        text-align: center;
        align-items: center;
      }

      .hero-panel h1 { font-size: 2.2rem; }
      .hero-panel .description { max-width: 100%; }
      .form-panel { padding: 0.8rem 0.8rem 1rem; align-items: flex-start; }
      .auth-card { width: min(100%, 500px); }
      .device-pill { left: 50%; transform: translateX(-50%); bottom: 0.7rem; }
    }

    @media (max-width: 840px) {
      .app-shell { grid-template-columns: 1fr; }
      .hero-panel { padding: 1rem 1rem 0.6rem; text-align: center; align-items: center; }
      .form-panel { padding: 0.7rem; }
    }

    .dashboard-shell {
      display: none;
      width: 100vw;
      height: 100dvh;
      background: linear-gradient(135deg, #f7f4eb 0%, #f1e1b0 100%);
      color: var(--navy);
      position: fixed;
      inset: 0;
      z-index: 10;
    }

    .dashboard-shell.show {
      display: flex;
    }

    .dashboard-sidebar {
      width: 280px;
      background: linear-gradient(180deg, var(--navy), #071427);
      color: white;
      padding: 1.4rem 1rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      margin-bottom: 1rem;
    }

    .brand-badge {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(145deg, var(--yellow), #f7a129);
      color: var(--navy);
      display: grid;
      place-items: center;
      font-weight: 800;
      font-size: 1.2rem;
    }

    .brand-title {
      font-size: 1.05rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .brand-subtitle {
      font-size: 0.82rem;
      opacity: 0.72;
    }

    .nav-item {
      border: none;
      background: transparent;
      color: rgba(255,255,255,0.86);
      text-align: left;
      padding: 0.8rem 0.9rem;
      border-radius: 14px;
      font-size: 0.98rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .nav-item:hover,
    .nav-item.active {
      background: rgba(255,255,255,0.14);
      color: #fff;
    }

    .dashboard-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .topbar {
      padding: 1rem 1.3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(15, 42, 75, 0.12);
      background: rgba(255,255,255,0.75);
      backdrop-filter: blur(8px);
    }

    .profile-pill {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      font-weight: 700;
    }

    .profile-photo {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      border: 2px solid var(--blue);
      background: linear-gradient(145deg, var(--champagne), var(--champagne-2));
      color: var(--navy);
      font-weight: 800;
      cursor: pointer;
    }

    .topbar-title {
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--navy);
    }

    .topbar-actions {
      display: flex;
      gap: 0.6rem;
    }

    .ghost-btn {
      border: 1px solid rgba(15, 42, 75, 0.14);
      background: white;
      color: var(--navy);
      padding: 0.65rem 0.9rem;
      border-radius: 999px;
      font-weight: 700;
      cursor: pointer;
    }

    .content-area {
      flex: 1;
      padding: 1.2rem;
      overflow: auto;
    }

    .view-panel {
      display: none;
      gap: 1rem;
      flex-direction: column;
    }

    .view-panel.active {
      display: flex;
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .panel-card {
      background: white;
      border-radius: 22px;
      padding: 1rem;
      box-shadow: 0 10px 24px rgba(15, 42, 75, 0.10);
      border: 1px solid rgba(15, 42, 75, 0.08);
    }

    .panel-card h3 {
      margin: 0 0 0.65rem;
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--navy);
    }

    .subject-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }

    .subject-chip {
      border: none;
      border-radius: 999px;
      padding: 0.65rem 0.9rem;
      background: linear-gradient(145deg, var(--champagne), var(--champagne-2));
      color: var(--navy);
      font-weight: 700;
      cursor: pointer;
    }

    .status-bars {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.7rem;
    }

    .bar-row {
      display: grid;
      grid-template-columns: 90px 1fr 40px;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.9rem;
    }

    .bar-track {
      height: 8px;
      background: #efe7c8;
      border-radius: 999px;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      background: linear-gradient(145deg, var(--blue), var(--yellow));
      border-radius: inherit;
    }

    .form-grid {
      display: grid;
      gap: 0.8rem;
    }

    .form-grid textarea,
    .form-grid input,
    .form-grid select {
      border: 1px solid rgba(15, 42, 75, 0.14);
      border-radius: 14px;
      padding: 0.8rem 0.9rem;
      font-size: 0.95rem;
      width: 100%;
    }

    .table-list {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .table-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.75rem 0.9rem;
      border-radius: 14px;
      background: #f9f3db;
      color: var(--navy);
      font-weight: 700;
    }

    .tiny-note {
      font-size: 0.84rem;
      color: rgba(15, 42, 75, 0.75);
      margin-top: 0.3rem;
    }

    .profile-upload {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .avatar-preview {
      width: 86px;
      height: 86px;
      border-radius: 50%;
      background: linear-gradient(145deg, var(--champagne), var(--champagne-2));
      display: grid;
      place-items: center;
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--navy);
      border: 2px solid var(--blue);
    }

    .scanner-box {
      border: 2px dashed rgba(15, 42, 75, 0.18);
      border-radius: 20px;
      padding: 1rem;
      background: #fbf7e9;
      min-height: 140px;
      display: grid;
      place-items: center;
      text-align: center;
      color: var(--navy);
      font-weight: 700;
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.8rem;
    }

    .grade-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.7rem 0.8rem;
      border-radius: 12px;
      background: #f9f4dc;
      font-weight: 700;
      color: var(--navy);
    }

    .badge-pill {
      display: inline-flex;
      padding: 0.35rem 0.6rem;
      border-radius: 999px;
      background: rgba(22, 60, 107, 0.12);
      color: var(--blue);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    @media (max-width: 900px) {
      .dashboard-shell { flex-direction: column; }
      .dashboard-sidebar { width: 100%; }
      .topbar { flex-wrap: wrap; gap: 0.7rem; }
    }
  </style>
</head>
<body>
  <div class="app-shell" id="authShell">
    <section class="hero-panel" id="heroPanel">
      <div class="eyebrow">Secure Access Portal</div>
      <h1>MAACSYS</h1>
      <p class="description">Developed to help teachers <span class="highlight">a bit</span> LOL!</p>
      <p class="description">Guided by <span class="highlight">Thrones Corporation International</span> and Enhanced Aria Bot.</p>
      <div class="device-pill" id="devicePill">Detecting device…</div>
    </section>

    <section class="form-panel">
      <div class="auth-card register-mode" id="authCard">
        <div class="card-header">
          <div>
            <div class="tiny">Teacher Access</div>
            <div class="card-title">Register Account</div>
          </div>
          <div class="tiny" id="cardBadge">New User</div>
        </div>

        <div class="field register-only">
          <label for="username">Username</label>
          <input id="username" placeholder="Enter teacher username" />
        </div>

        <div class="field register-only">
          <label for="cell">Cell Number <span style="font-size:0.85rem; color:var(--navy);">(Optional)</span></label>
          <select id="countryCode">
            <option value="+63">+63 (PH)</option>
            <option value="+1">+1</option>
            <option value="+44">+44</option>
            <option value="+61">+61</option>
          </select>
          <input id="cell" placeholder="9123456789 (for SMS on mobile)" />
        </div>

        <div class="field register-only">
          <label for="password">Password</label>
          <div class="password-wrap">
            <input id="password" type="password" placeholder="Create a strong password" />
            <button class="toggle" type="button" id="togglePassword">SHOW</button>
          </div>
        </div>

        <div class="field login-only">
          <label for="loginUser">Username</label>
          <input id="loginUser" placeholder="Enter registered username" />
        </div>

        <div class="field login-only">
          <label for="loginPassword">Password</label>
          <div class="password-wrap">
            <input id="loginPassword" type="password" placeholder="Enter your password" />
            <button class="toggle" type="button" id="toggleLoginPassword">SHOW</button>
          </div>
        </div>

        <div class="actions">
          <button class="btn" id="mainAction">Register</button>
          <div class="helper-row">
            <button class="link-btn" id="switchMode">Already Registered? Log in!</button>
            <button class="link-btn" id="forgotLink" style="display:none;">Forgot Password?</button>
          </div>
        </div>

        <div class="status" id="statusText">Please fill in the details to continue.</div>
      </div>
    </section>
  </div>

  <div class="dashboard-shell" id="dashboardShell">
    <aside class="dashboard-sidebar">
      <div class="brand">
        <div class="brand-badge">M</div>
        <div>
          <div class="brand-title">MAACSYS</div>
          <div class="brand-subtitle">Teacher Portal</div>
        </div>
      </div>

      <button class="nav-item active" data-view="home">Home</button>
      <button class="nav-item" data-view="settings">Settings</button>
      <button class="nav-item" data-view="database">Classes</button>
      <button class="nav-item" data-view="inbox">Inbox</button>
      <button class="nav-item" data-view="account">Account</button>
    </aside>

    <div class="dashboard-main">
      <header class="topbar">
        <div class="profile-pill">
          <button class="profile-photo" id="profilePhotoBtn">TP</button>
          <div>Teacher Profile</div>
        </div>
        <div class="topbar-title">MAACSYS</div>
        <div class="topbar-actions">
          <button class="ghost-btn">Notifications</button>
          <button class="ghost-btn">Logout</button>
        </div>
      </header>

      <main class="content-area">
        <section class="view-panel active" id="view-home">
          <div class="card-grid">
            <div class="panel-card">
              <h3>Subjects</h3>
              <div class="subject-row">
                <button class="subject-chip">Math</button>
                <button class="subject-chip">English</button>
                <button class="subject-chip">Science</button>
                <button class="subject-chip">History</button>
              </div>
            </div>
            <div class="panel-card">
              <h3>Attendance Snapshot</h3>
              <div class="status-bars">
                <div class="bar-row"><span>Present</span><div class="bar-track"><div class="bar-fill" style="width: 82%"></div></div><span>82%</span></div>
